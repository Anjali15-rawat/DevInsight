# ──────────────────────────────────────────────────────────────────────────────
# DevInsight Backend — Environment Variables
# Copy this file to .env and fill in real values before running.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=development          # development | production
DEBUG=true
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
FRONTEND_URL=http://localhost:5173

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://devinsight:devinsight_dev_password@localhost:5432/devinsight

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── GitHub OAuth App ─────────────────────────────────────────────────────────
# Create an OAuth App at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your-github-oauth-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback

# ─── GitHub App (for webhook + repo access at scale) ─────────────────────────
# Create a GitHub App at: https://github.com/settings/apps
GITHUB_APP_ID=your-github-app-id
GITHUB_APP_PRIVATE_KEY_PATH=./github_app_private_key.pem
GITHUB_WEBHOOK_SECRET=your-webhook-secret-generate-random-string

# ─── Google Gemini AI ─────────────────────────────────────────────────────────
# Get free API key at: https://aistudio.google.com/
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# ─── JWT Tokens ───────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── RAG / FAISS ──────────────────────────────────────────────────────────────
FAISS_INDEX_PATH=./faiss_index/devinsight.index
EMBEDDING_MODEL=all-MiniLM-L6-v2
RAG_TOP_K=5                # Number of chunks to retrieve per query
CHUNK_SIZE=400             # Target tokens per chunk
CHUNK_OVERLAP=50           # Overlap tokens between chunks

# ─── Supabase Storage (optional, for document uploads) ────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_BUCKET=devinsight-knowledge

# ─── AI Agent Settings ────────────────────────────────────────────────────────
AGENT_MAX_DIFF_TOKENS=50000    # Max tokens of diff to send to an agent
AGENT_TIMEOUT_SECONDS=120      # Timeout for a single agent LLM call

# ─── Rate Limiting ────────────────────────────────────────────────────────────
GITHUB_API_RATE_LIMIT=5000     # GitHub requests per hour per token

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
